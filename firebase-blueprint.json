{
  "entities": {
    "userProfiles": {
      "title": "User Profiles",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "comments": {
      "title": "Comments",
      "description": "User reviews and feedback",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "text", "createdAt"]
    },
    "applications": {
      "title": "Job Applications",
      "description": "Candidate job applications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "profession": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "contacted", "rejected"] }
      },
      "required": ["name", "email", "phone", "profession", "createdAt", "status"]
    }
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "userProfiles",
      "description": "Store user profiles by UID"
    },
    "/comments/{commentId}": {
      "schema": "comments",
      "description": "Public reviews"
    },
    "/applications/{applicationId}": {
      "schema": "applications",
      "description": "Private job applications"
    }
  }
}
