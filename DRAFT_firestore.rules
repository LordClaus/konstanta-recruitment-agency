rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Role-based lookup (Assumes /admins/{userId} exists for admins)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Entity Validations ---

    function isValidComment(data) {
      return data.keys().hasAll(['userName', 'text', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.text is string && data.text.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'profession', 'createdAt', 'status']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.profession is string && data.profession.size() <= 100 &&
             data.status in ['pending', 'reviewed', 'contacted', 'rejected'] &&
             data.createdAt == request.time;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email == request.auth.token.email &&
             data.createdAt == request.time;
    }

    // --- Rules ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
    }

    match /comments/{commentId} {
      allow list: if true; // Public reviews
      allow get: if true;
      allow create: if isSignedIn() && isValidComment(incoming()) && 
                    (incoming().userId == request.auth.uid || !incoming().keys().hasAny(['userId']));
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /applications/{applicationId} {
      // Allow anyone to submit (even guests), but if signed in, must match UID
      allow create: if isValidApplication(incoming()) && 
                    (!incoming().keys().hasAny(['userId']) || incoming().userId == request.auth.uid);
      
      // Only admin or the owner of the application can see it
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Temporary Admin Seed (Replace with real system or restricted collection)
    match /admins/{userId} {
      allow read: if isSignedIn();
    }
  }
}
